[submodule ".registry"]
	path = .registry
	url = https://github.com/r-universe-org/cran-to-git
	shallow = true
	branch = HEAD
[submodule "E4tools"]
	path = E4tools
	url = https://github.com/cran/E4tools
	shallow = true
	registered = true
[submodule "EMAtools"]
	path = EMAtools
	url = https://github.com/ekleiman1/ematools
	shallow = true
	registered = true
